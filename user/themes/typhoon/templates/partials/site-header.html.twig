{# Canonical site header — single source of truth for all marketing pages.
   Include with:  {% include 'partials/site-header.html.twig' with {active: 'product'} %}
   active ∈ '' | cashbook | product | self-host | resources | blog | download | pre-order
   Primary nav is deliberately lean (6 items). Secondary destinations (Forum,
   Build log) live in the mobile menu and in every page footer.
   Docs + Forum (our own sub-sites) open in the SAME tab — keep low-resource clients on one tab.
   Below 1024px the primary nav + action buttons collapse into the CSS-only
   <details> disclosure menu (no JavaScript — survives the static mirror). #}
{% set active = active|default('') %}
<header class="site-header">
  <div class="container row">
    <a href="/" class="wordmark" aria-label="SAE Books home">
      <img src="/user/data/sae-books-logo.png" alt="SAE Books">
    </a>
    <nav class="primary">
      <a href="/product"{% if active == 'product' %} class="is-active"{% endif %}>Product</a>
      <a href="/cashbook"{% if active == 'cashbook' %} class="is-active"{% endif %}>Cashbook</a>
      <a href="/self-host"{% if active == 'self-host' %} class="is-active"{% endif %}>Self-host</a>
      <a href="/#editions">Pricing</a>
      <a href="/resources"{% if active == 'resources' %} class="is-active"{% endif %}>Resources</a>
      <a href="https://dev.saebooks.com.au">Docs</a>
    </nav>
    <div class="header-spacer"></div>
    <div class="header-actions">
      <a href="/download" class="btn btn-secondary{% if active == 'download' %} is-active{% endif %}">Free download</a>
      <a href="https://cashbook-demo.saebooks.com.au" class="btn btn-primary" target="_blank" rel="noopener">Try the demo</a>
    </div>
    <details class="nav-menu">
      <summary aria-label="Menu">
        <svg class="lucide menu-open" viewBox="0 0 24 24" aria-hidden="true"><line x1="3" y1="6" x2="21" y2="6"/><line x1="3" y1="12" x2="21" y2="12"/><line x1="3" y1="18" x2="21" y2="18"/></svg>
        <svg class="lucide menu-close" viewBox="0 0 24 24" aria-hidden="true"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
      </summary>
      <div class="nav-menu-panel">
        <a href="/product">Product</a>
        <a href="/cashbook">Cashbook</a>
        <a href="/self-host">Self-host</a>
        <a href="/#editions">Pricing</a>
        <a href="/resources">Resources</a>
        <a href="https://dev.saebooks.com.au">Docs</a>
        <a href="https://discourse.saebooks.com.au">Forum</a>
        <a href="/blog">Build log</a>
        <div class="nav-menu-cta">
          <a href="/download" class="btn btn-secondary">Free download</a>
          <a href="https://cashbook-demo.saebooks.com.au" class="btn btn-primary" target="_blank" rel="noopener">Try the demo</a>
        </div>
      </div>
    </details>
  </div>
</header>
