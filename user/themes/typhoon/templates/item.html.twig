{# Single post template — self-contained, matches homepage + blog listing chrome. #}
<!DOCTYPE html>
<html lang="{{ grav.language.getActive ?: grav.config.site.default_lang }}">
<head>
  <meta charset="utf-8"/>
  <title>{{ header.title|e('html') }} | {{ site.title|e('html') }}</title>
  <meta http-equiv="X-UA-Compatible" content="IE=edge"/>
  <meta name="viewport" content="width=device-width, initial-scale=1"/>
  {% set description = page.summary(160, true)|striptags %}
  {% if description %}<meta name="description" content="{{ description|e('html') }}"/>{% endif %}
  <link rel="icon" type="image/png" href="/user/data/sae-books-logo.png"/>
  <link rel="canonical" href="{{ page.url(true, true)|replace({'http://': 'https://'}) }}"/>
  {% include 'partials/social-meta.html.twig' %}
  {% set v = page.modified|default('1') %}
  <link rel="stylesheet" href="/user/data/colors_and_type.css?v={{ v }}"/>
  <link rel="stylesheet" href="/user/data/saebooks.css?v={{ v }}"/>
  <style>
    /* Single post page extras */
    .post-header { padding: 48px 0 32px; border-bottom: 1px solid var(--border); margin-bottom: 40px; }
    .post-header .post-meta { font-size: var(--fs-meta); color: var(--muted); margin-bottom: 12px; }
    .post-header h1 { font-size: clamp(1.75rem, 3vw, 2.5rem); font-weight: 700; line-height: 1.2; margin-bottom: 0; }
    .post-body { max-width: 680px; }
    .post-body h2 { margin-top: 40px; }
    .post-body h3 { margin-top: 28px; }
    .post-body p { line-height: 1.7; }
    .post-body code { background: var(--subtle); padding: 2px 6px; border-radius: var(--radius-sm); font-size: 0.9em; }
    .post-body pre { background: var(--subtle); border: 1px solid var(--border); border-radius: var(--radius); padding: 16px; overflow-x: auto; }
    html.dark .post-body code, html.dark .post-body pre { background: var(--surface); border-color: var(--border); }
    .post-body blockquote { border-left: 3px solid var(--brand-navy); margin-left: 0; padding-left: 20px; color: var(--muted); }
    .post-footer { margin-top: 48px; padding-top: 24px; border-top: 1px solid var(--border); display: flex; flex-wrap: wrap; align-items: center; gap: 16px; }
    .post-tags { display: flex; flex-wrap: wrap; gap: 6px; }
    .tag-chip {
      display: inline-block; padding: 2px 10px;
      border: 1px solid var(--border-strong);
      border-radius: var(--radius-pill);
      font-size: var(--fs-meta); color: var(--muted);
      background: var(--subtle);
    }
    html.dark .tag-chip { background: var(--surface); border-color: var(--border); }
    .back-link { font-size: var(--fs-small); font-weight: 600; color: var(--brand-navy); margin-right: auto; }
    .back-link:hover { color: var(--brand-navy-700); text-decoration: underline; }
    html.dark .back-link { color: #93a5d6; }
    .post-wrap { padding-bottom: 96px; }
  </style>
  <script>
    (function () {
      try {
        var saved = (localStorage.getItem('saebooks-theme')||localStorage.getItem('sae-books-theme'));
        var theme = saved || 'auto';
        var resolved = theme;
        if (theme === 'auto') {
          resolved = window.matchMedia('(prefers-color-scheme: dark)').matches ? 'dark' : 'light';
        }
        document.documentElement.classList.remove('light', 'dark');
        document.documentElement.classList.add(resolved);
        document.documentElement.setAttribute('data-theme', resolved);
      } catch (e) {}
    })();
  </script>
</head>
<body class="blog-page">

{% include 'partials/site-header.html.twig' with {active: 'blog'} %}

<main class="post-wrap">
  <div class="container">
    <div class="post-header">
      <div class="post-meta">{{ page.date|date('j F Y') }}</div>
      <h1>{{ header.title|e }}</h1>
    </div>

    <div class="post-body">
      {{ page.content|raw }}
    </div>

    <div class="post-footer">
      <a class="back-link" href="/blog">&larr; Back to build log</a>
      {% if header.taxonomy.tag is defined %}
        <div class="post-tags">
          {% for tag in header.taxonomy.tag %}
            <span class="tag-chip">{{ tag|e }}</span>
          {% endfor %}
        </div>
      {% endif %}
    </div>
  </div>
</main>

<footer class="site">
  <div class="container">
    <div class="foot-grid">
      <div class="foot-col foot-brand">
        <a href="/" class="wordmark"><img src="/user/data/sae-books-logo.png" alt="SAE Books" style="height:40px;"></a>
        <p class="blurb">An API-first accounting ledger for Australian small business. Free Community edition for self-host, paid tiers for double-entry, payroll, and BAS. AGPLv3, owned by you.</p>
      </div>
      <div class="foot-col">
        <h5>Product</h5>
        <ul>
          <li><a href="https://github.com/saebooks/saebooks">Self-host (Community)</a></li>
          <li><a href="https://cashbook-demo.saebooks.com.au">Try the demo</a></li>
          <li><a href="/#editions">Pricing &amp; plans</a></li>
          <li><a href="/preview-access">Talk to us (Enterprise)</a></li>
        </ul>
      </div>
      <div class="foot-col">
        <h5>Build</h5>
        <ul>
          <li><a href="https://dev.saebooks.com.au">Docs</a></li>
          <li><a href="https://discourse.saebooks.com.au">Forum</a></li>
          <li><a href="https://github.com/saebooks/saebooks">GitHub</a></li>
          <li><a href="https://github.com/saebooks/saebooks/releases">Changelog</a></li>
          <li><a href="/blog">Build log</a></li>
        </ul>
      </div>
      <div class="foot-col">
        <h5>Company</h5>
        <ul>
          <li><a href="https://sauer.com.au">SAE Engineering</a></li>
          <li><a href="/preview-access">Contact</a></li>
          <li><a href="https://www.gnu.org/licenses/agpl-3.0.en.html">Licence (AGPLv3)</a></li>
        </ul>
      </div>
    </div>
    <div class="foot-bottom">
      <span>&copy; 2026 Sauer Pty Ltd &middot; ABN 87 744 586 592 &middot; ACN 683 275 756 &middot; Cairns, QLD</span>
      <span>Source available under <a href="https://www.gnu.org/licenses/agpl-3.0.en.html">AGPLv3</a>.</span>
    </div>
  </div>
</footer>

<div class="mobile-cta">
  <a href="https://dev.saebooks.com.au/getting-started/quickstart/" class="btn btn-primary">Get started</a>
  <a href="https://cashbook-demo.saebooks.com.au" class="btn btn-secondary">Try the demo</a>
</div>

{% include 'partials/theme-controls.html.twig' %}
</body>
</html>
