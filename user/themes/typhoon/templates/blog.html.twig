{# Blog listing template — self-contained, matches homepage chrome.
   Uses same CSS as homepage.html.twig (colors_and_type.css + saebooks.css). #}
<!DOCTYPE html>
<html lang="{{ grav.language.getActive ?: grav.config.site.default_lang }}">
<head>
  <meta charset="utf-8"/>
  <title>{{ header.title|e('html') }} | {{ site.title|e('html') }}</title>
  <meta http-equiv="X-UA-Compatible" content="IE=edge"/>
  <meta name="viewport" content="width=device-width, initial-scale=1"/>
  <meta name="description" content="Build log — SAE Books development updates, architecture notes, and release announcements."/>
  <link rel="icon" type="image/png" href="/user/data/sae-books-logo.png"/>
  <link rel="canonical" href="{{ page.url(true, true)|replace({'http://': 'https://'}) }}"/>
  {% include 'partials/social-meta.html.twig' %}
  {% if config.plugins.feed.enabled %}
  <link rel="alternate" type="application/rss+xml" title="{{ site.title }} Build log" href="{{ base_url }}/blog.rss"/>
  {% endif %}
  {% set v = page.modified|default('1') %}
  <link rel="stylesheet" href="/user/data/colors_and_type.css?v={{ v }}"/>
  <link rel="stylesheet" href="/user/data/saebooks.css?v={{ v }}"/>
  <style>
    /* Blog listing page extras */
    .blog-header { padding: 48px 0 32px; border-bottom: 1px solid var(--border); margin-bottom: 48px; }
    .blog-header h1 { margin-bottom: 8px; }
    .blog-header p { color: var(--muted); font-size: var(--fs-small); margin: 0; }
    .post-list { list-style: none; margin: 0; padding: 0; }
    .post-list li + li { border-top: 1px solid var(--border); }
    .post-card { padding: 32px 0; }
    .post-card .post-meta { font-size: var(--fs-meta); color: var(--muted); margin-bottom: 10px; }
    .post-card h2 { font-size: var(--fs-h3); font-weight: 700; margin-bottom: 10px; line-height: 1.3; }
    .post-card h2 a { color: var(--ink); }
    .post-card h2 a:hover { color: var(--brand-navy); text-decoration: none; }
    html.dark .post-card h2 a { color: #e5e7eb; }
    html.dark .post-card h2 a:hover { color: #93a5d6; }
    .post-excerpt { color: var(--body); font-size: var(--fs-body); line-height: 1.6; margin-bottom: 14px; }
    .post-tags { display: flex; flex-wrap: wrap; gap: 6px; margin-bottom: 14px; }
    .tag-chip {
      display: inline-block; padding: 2px 10px;
      border: 1px solid var(--border-strong);
      border-radius: var(--radius-pill);
      font-size: var(--fs-meta); color: var(--muted);
      background: var(--subtle);
    }
    html.dark .tag-chip { background: var(--surface); border-color: var(--border); }
    .read-more { font-size: var(--fs-small); font-weight: 600; color: var(--brand-navy); }
    .read-more:hover { color: var(--brand-navy-700); text-decoration: underline; }
    html.dark .read-more { color: #93a5d6; }
    /* Pagination */
    .blog-pagination { display: flex; justify-content: center; gap: 8px; padding: 40px 0 64px; }
    .blog-pagination a, .blog-pagination span {
      display: inline-flex; align-items: center; justify-content: center;
      width: 36px; height: 36px; border-radius: var(--radius);
      border: 1px solid var(--border-strong);
      font-size: var(--fs-small); font-weight: 600;
      color: var(--body); background: var(--surface);
      text-decoration: none;
    }
    .blog-pagination a:hover { background: var(--subtle); color: var(--ink); }
    .blog-pagination .active { background: var(--brand-navy); color: #fff; border-color: var(--brand-navy); }
    html.dark .blog-pagination a { background: var(--surface); color: #d1d5db; }
  </style>
  <script>
    (function () {
      try {
        var saved = (localStorage.getItem('saebooks-theme')||localStorage.getItem('sae-books-theme'));
        var theme = saved || 'auto';
        var resolved = theme;
        if (theme === 'auto') {
          resolved = window.matchMedia('(prefers-color-scheme: dark)').matches ? 'dark' : 'light';
        }
        document.documentElement.classList.remove('light', 'dark');
        document.documentElement.classList.add(resolved);
        document.documentElement.setAttribute('data-theme', resolved);
      } catch (e) {}
    })();
  </script>
</head>
<body class="blog-page">

{% include 'partials/site-header.html.twig' with {active: 'blog'} %}

<main>
  <div class="container">
    <div class="blog-header">
      <h1>Build log</h1>
      <p>Development updates, architecture notes, and release announcements.</p>
    </div>

    {% set collection = page.collection() %}
    <ul class="post-list">
      {% for post in collection %}
        <li>
          <div class="post-card">
            <div class="post-meta">{{ post.date|date('j F Y') }}</div>
            <h2><a href="{{ post.url }}">{{ post.header.title|e }}</a></h2>
            {% set excerpt = post.summary(120, true)|striptags %}
            {% if excerpt %}<p class="post-excerpt">{{ excerpt }}</p>{% endif %}
            {% if post.header.taxonomy.tag is defined %}
            <div class="post-tags">
              {% for tag in post.header.taxonomy.tag %}
                <span class="tag-chip">{{ tag|e }}</span>
              {% endfor %}
            </div>
            {% endif %}
            <a class="read-more" href="{{ post.url }}">Read more &rarr;</a>
          </div>
        </li>
      {% else %}
        <li><p style="color:var(--muted);padding:32px 0;">No posts yet.</p></li>
      {% endfor %}
    </ul>

    {% if config.plugins.pagination.enabled %}
      {% set pagination = collection.params.pagination %}
      {% if pagination and pagination.last > 1 %}
        <nav class="blog-pagination" aria-label="Page navigation">
          {% if pagination.current > 1 %}
            <a href="{{ page.url }}/page:{{ pagination.current - 1 }}" aria-label="Previous page">&laquo;</a>
          {% endif %}
          {% for i in 1..pagination.last %}
            {% if i == pagination.current %}
              <span class="active" aria-current="page">{{ i }}</span>
            {% else %}
              <a href="{{ page.url }}/page:{{ i }}">{{ i }}</a>
            {% endif %}
          {% endfor %}
          {% if pagination.current < pagination.last %}
            <a href="{{ page.url }}/page:{{ pagination.current + 1 }}" aria-label="Next page">&raquo;</a>
          {% endif %}
        </nav>
      {% endif %}
    {% endif %}
  </div>
</main>

<footer class="site">
  <div class="container">
    <div class="foot-grid">
      <div class="foot-col foot-brand">
        <a href="/" class="wordmark"><img src="/user/data/sae-books-logo.png" alt="SAE Books" style="height:40px;"></a>
        <p class="blurb">An API-first accounting ledger for Australian small business. Free Community edition for self-host, paid tiers for double-entry, payroll, and BAS. AGPLv3, owned by you.</p>
      </div>
      <div class="foot-col">
        <h5>Product</h5>
        <ul>
          <li><a href="https://github.com/saebooks/saebooks">Self-host (Community)</a></li>
          <li><a href="https://cashbook-demo.saebooks.com.au">Try the demo</a></li>
          <li><a href="/#editions">Pricing &amp; plans</a></li>
          <li><a href="/preview-access">Talk to us (Enterprise)</a></li>
        </ul>
      </div>
      <div class="foot-col">
        <h5>Build</h5>
        <ul>
          <li><a href="https://dev.saebooks.com.au">Docs</a></li>
          <li><a href="https://discourse.saebooks.com.au">Forum</a></li>
          <li><a href="https://github.com/saebooks/saebooks">GitHub</a></li>
          <li><a href="https://github.com/saebooks/saebooks/releases">Changelog</a></li>
          <li><a href="/blog">Build log</a></li>
        </ul>
      </div>
      <div class="foot-col">
        <h5>Company</h5>
        <ul>
          <li><a href="https://sauer.com.au">SAE Engineering</a></li>
          <li><a href="/preview-access">Contact</a></li>
          <li><a href="https://www.gnu.org/licenses/agpl-3.0.en.html">Licence (AGPLv3)</a></li>
        </ul>
      </div>
    </div>
    <div class="foot-bottom">
      <span>&copy; 2026 Sauer Pty Ltd &middot; ABN 87 744 586 592 &middot; ACN 683 275 756 &middot; Cairns, QLD</span>
      <span>Source available under <a href="https://www.gnu.org/licenses/agpl-3.0.en.html">AGPLv3</a>.</span>
    </div>
  </div>
</footer>

<div class="mobile-cta">
  <a href="https://dev.saebooks.com.au/getting-started/quickstart/" class="btn btn-primary">Get started</a>
  <a href="https://cashbook-demo.saebooks.com.au" class="btn btn-secondary">Try the demo</a>
</div>

{% include 'partials/theme-controls.html.twig' %}
</body>
</html>
