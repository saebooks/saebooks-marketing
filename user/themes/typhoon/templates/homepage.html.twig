{# Self-contained marketing template — bypasses Typhoon's chrome entirely.
   Emits a minimal HTML document that loads only colors_and_type.css +
   saebooks.css from user/data/, then drops in the page content as-is. #}
<!DOCTYPE html>
<html lang="{{ grav.language.getActive ?: grav.config.site.default_lang }}">
<head>
  <meta charset="utf-8"/>
  <title>{% if header.title %}{{ header.title|e('html') }} | {% endif %}{{ site.title|e('html') }}</title>
  <meta http-equiv="X-UA-Compatible" content="IE=edge"/>
  <meta name="viewport" content="width=device-width, initial-scale=1"/>
  {% set _pd = header.metadata.description|default(site.metadata.description) %}{% if _pd %}<meta name="description" content="{{ _pd|e('html') }}"/>{% endif %}
  {% if site.metadata.keywords %}<meta name="keywords" content="{{ site.metadata.keywords|e('html') }}"/>{% endif %}
  <link rel="icon" type="image/png" href="/user/data/sae-books-logo.png"/>
  <link rel="canonical" href="{{ page.url(true, true)|replace({'http://': 'https://'}) }}"/>
  {% include 'partials/social-meta.html.twig' %}

  {# Cache-bust via page mtime so browsers don't serve stale CSS after a deploy #}
  {% set v = page.modified|default('1') %}
  <link rel="stylesheet" href="/user/data/colors_and_type.css?v={{ site.assets_version|default(v) }}"/>
  <link rel="stylesheet" href="/user/data/saebooks.css?v={{ site.assets_version|default(v) }}"/>

  <script>
    (function () {
      try {
        var K = 'saebooks-theme', OLD = 'sae-books-theme';
        if (!localStorage.getItem(K)) {           /* one-time migration from old key */
          var o = localStorage.getItem(OLD);
          if (o === 'light' || o === 'dark') localStorage.setItem(K, o);
        }
        var saved = localStorage.getItem(K);
        var choice = (saved === 'light' || saved === 'dark') ? saved : 'auto';
        var resolved = choice === 'auto'
          ? (window.matchMedia('(prefers-color-scheme: dark)').matches ? 'dark' : 'light')
          : choice;
        var e = document.documentElement;
        e.classList.remove('light', 'dark');
        e.classList.add(resolved);
        if (choice === 'auto') e.removeAttribute('data-theme');
        else e.setAttribute('data-theme', choice);
      } catch (e) {}
    })();
  </script>
</head>
<body class="homepage">
{% include 'partials/site-header.html.twig' with {active: header.header_active|default('')} %}
{{ page.content|raw }}
{% include 'partials/theme-controls.html.twig' %}
</body>
</html>
