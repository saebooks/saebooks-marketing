# ===== saebooks.com.au Grav source — managed paths only =====
# Canonical SOURCE for the marketing site. Edit here, then ./deploy.sh -> live.

# ── Grav cache & runtime ──
user/cache/
user/logs/
user/tmp/
user/backup/
user/env/

# ── Secrets & accounts (NEVER commit) ──
user/accounts/
user/config/security.yaml
user/config/security-private.php
user/config/plugins/email.yaml
user/config/plugins/login-oauth2.yaml
user/data/licenses.yaml
user/data/rememberme/

# ── Runtime data / form submissions (PII) ──
user/data/preview-access/
user/data/contact/
user/data/feed/
user/data/flex/
user/data/notifications/
user/data/scheduler/

# ── Plugins: GPM-managed on live, not part of the source deploy ──
user/plugins/

# ── Premium Typhoon theme: track ONLY our template overrides ──
user/themes/typhoon/*
!user/themes/typhoon/templates/
user/themes/quark/

# ── Backups & compiled ──
*.bak
*.bak.*
*.bak-*
user/themes/*/node_modules/

# ── OS ──
.DS_Store
Thumbs.db

# ── build/working ──
graphify-out/
